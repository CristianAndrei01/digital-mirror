# Digital Mirror — Mirror Watcher Configuration
# Copy this file to /opt/mirror-watcher/.env and fill in your values

# ── Mirror API ───────────────────────────────────────────────
MIRROR_ENDPOINT=http://localhost:3000/api/entry
MIRROR_API_BASE=http://localhost:3000/api
MIRROR_API_KEY=your_api_key_here

# ── Adapter ──────────────────────────────────────────────────
# Options: openclaw, webhook
MIRROR_ADAPTER=openclaw

# ── OpenClaw adapter ─────────────────────────────────────────
OPENCLAW_HOME=/home/openclaw/.openclaw

# ── Webhook adapter (if MIRROR_ADAPTER=webhook) ──────────────
# WEBHOOK_PORT=3100

# ── Polling ──────────────────────────────────────────────────
POLL_INTERVAL=2000
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000

# ── Telegram Push Notifications ──────────────────────────────
# Get your bot token from @BotFather on Telegram
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Proactive Alerts ─────────────────────────────────────────
# How often to check for alerts (in minutes). Default: 30
ALERT_CHECK_MINS=30

# ── Weekly Digest ────────────────────────────────────────────
# Default day and hour for weekly digest push
# These are overridden at runtime by /api/settings (set via dashboard or agent)
WEEKLY_DIGEST_DAY=monday
WEEKLY_DIGEST_HOUR=8
USER_TIMEZONE=Europe/Bucharest

# ── State file ───────────────────────────────────────────────
STATE_FILE=/opt/mirror-watcher/watcher-state.json
