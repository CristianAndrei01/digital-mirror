# Digital Mirror — Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
HOST=0.0.0.0

# Database (SQLite file path — relative to project root)
DB_PATH=./data/mirror.db

# Base currency (ISO 4217 code)
BASE_CURRENCY=USD

# Scoring — adaptive threshold multiplier (default: 0.4)
# Lower value = more sensitive direction detection (fewer Stable classifications)
# Higher value = more conservative (more Stable classifications)
SIGMA_MULTIPLIER=0.4

# Calibration period in days (default: 14)
CALIBRATION_DAYS=14

# API Key — protects all /api/* endpoints
# Leave empty to keep API open (not recommended for public deployments)
# MIRROR_API_KEY=your_secret_key_here

# Dashboard Password — protects the /dashboard route with HTTP Basic Auth
# Leave empty to keep dashboard open (not recommended for public deployments)
# DASHBOARD_PASSWORD=your_dashboard_password_here
