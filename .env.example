# Digital Mirror — Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
HOST=localhost

# Database (SQLite file path — relative to project root)
DB_PATH=./data/mirror.db

# Base currency (ISO 4217 code)
BASE_CURRENCY=USD

# Scoring — adaptive threshold multiplier (default: 0.4)
# Lower value = more sensitive direction detection (fewer Stable classifications)
# Higher value = more conservative (more Stable classifications)
SIGMA_MULTIPLIER=0.4

# Calibration period in days (default: 14)
CALIBRATION_DAYS=14

# OpenClaw API key (optional — for agent integration)
# OPENCLAW_API_KEY=your_key_here
