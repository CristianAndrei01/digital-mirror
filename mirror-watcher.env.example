# Digital Mirror — Session Watcher Configuration
# Copy this file to /opt/mirror-watcher/mirror-watcher.env and fill in values

# Adapter: openclaw | webhook
MIRROR_ADAPTER=openclaw

# Mirror API endpoint (your backend server)
MIRROR_ENDPOINT=http://YOUR_MIRROR_SERVER_IP:3000/api/entry

# Optional: API key for Mirror API authentication (leave blank if not set)
MIRROR_API_KEY=

# OpenClaw home directory (openclaw adapter only)
OPENCLAW_HOME=/home/openclaw/.openclaw

# Webhook port (webhook adapter only — V2)
# WEBHOOK_PORT=3100

# State file path (tracks byte offset between restarts)
STATE_FILE=/opt/mirror-watcher/watcher-state.json

# Poll interval in milliseconds
POLL_INTERVAL=2000

# Retry config for failed POSTs to Mirror API
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000
