# Digital Mirror — Session Watcher Configuration
# Copy this file to .env and fill in your values
# Install at: /opt/mirror-watcher/.env

# ─── Required ─────────────────────────────────────────────────
# URL of your Digital Mirror API server
MIRROR_ENDPOINT=http://YOUR_MIRROR_SERVER_IP:3000/api/entry

# ─── Authentication ───────────────────────────────────────────
# Must match MIRROR_API_KEY on your Mirror server (if set)
# MIRROR_API_KEY=your_secret_key_here

# ─── Adapter ──────────────────────────────────────────────────
# openclaw = reads OpenClaw session files from disk
# webhook  = starts HTTP server on WEBHOOK_PORT to receive POSTs
MIRROR_ADAPTER=openclaw

# ─── OpenClaw Adapter ─────────────────────────────────────────
OPENCLAW_HOME=/home/openclaw/.openclaw

# ─── Webhook Adapter ──────────────────────────────────────────
# WEBHOOK_PORT=3100

# ─── Polling ──────────────────────────────────────────────────
POLL_INTERVAL=2000

# ─── State ────────────────────────────────────────────────────
STATE_FILE=/opt/mirror-watcher/watcher-state.json
